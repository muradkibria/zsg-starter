# ─────────────────────────────────────────────────────────────────────────────
# Operating mode
# ─────────────────────────────────────────────────────────────────────────────
# MOCK=true   → fake data, no external services needed (frontend dev mode)
# MOCK=false  → live Colorlight Cloud integration
MOCK=false

# JWT (Express session signing for the dashboard's own auth wrapper)
JWT_SECRET=change-me-with-openssl-rand-base64-32

# ─────────────────────────────────────────────────────────────────────────────
# Colorlight Cloud — required when MOCK=false
# ─────────────────────────────────────────────────────────────────────────────
# Your tenant base URL (e.g. https://beu.colorlightcloud.com — no trailing slash)
COLORLIGHT_API_BASE=https://beu.colorlightcloud.com
COLORLIGHT_USERNAME=your-colorlight-username
COLORLIGHT_PASSWORD=your-colorlight-password

# ─────────────────────────────────────────────────────────────────────────────
# WRITE OPERATIONS SAFETY GATE
# ─────────────────────────────────────────────────────────────────────────────
# When false (default) the dashboard will NEVER actually upload media,
# create programs, or push to bags — every write call short-circuits and logs
# what *would* have happened. The UI shows a yellow "DEV MODE" banner.
#
# Flip this to true ONLY when you've reviewed the code paths and are ready
# for real Colorlight writes to fire. Riders pick up new content the moment
# you flip this on if there's a queued deploy. Treat with caution.
COLORLIGHT_WRITES_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# TEST-BAG MODE — staged rollout for live writes
# ─────────────────────────────────────────────────────────────────────────────
# If COLORLIGHT_WRITES_ENABLED is false BUT this var is set to one or more
# comma-separated bag IDs, the dashboard enters "test-bag mode":
#   - Uploads + program creation DO hit Colorlight for real
#   - Program → bag assignment is enforced per-bag: only the listed bag IDs
#     accept writes; any deploy targeting other bags is rejected with HTTP 403
#   - The banner turns blue ("TEST-BAG MODE") and non-listed bags appear
#     greyed-out in the deploy dialog
# Use this to validate the full upload+deploy flow on a single bag while the
# rest of your fleet remains untouched. Unset to return to pure dry-run, or
# flip COLORLIGHT_WRITES_ENABLED=true for fleet-wide writes.
# COLORLIGHT_TEST_BAG_IDS=5257479

# ─────────────────────────────────────────────────────────────────────────────
# Rider stationary detection (timesheet)
# ─────────────────────────────────────────────────────────────────────────────
# A "stationary window" is a continuous stretch of GPS reports where the rider
# stays within IDLE_RADIUS_M of a single point for at least
# IDLE_THRESHOLD_MINUTES. Those minutes are shown as "idle" on the timesheet
# (alongside raw and working hours) so payroll reflects actual moving time
# rather than just "bag was on".
# Defaults: 50 metres / 15 minutes.
# IDLE_RADIUS_M=50
# IDLE_THRESHOLD_MINUTES=15

# ─────────────────────────────────────────────────────────────────────────────
# Campaign reporting — Anthropic Claude integration
# ─────────────────────────────────────────────────────────────────────────────
# Required to generate AI-narrative campaign reports.
# Get your key at https://console.anthropic.com/ → API Keys.
# Reports use claude-haiku-4-5 by default (~$0.005–$0.010 per report).
# Set ANTHROPIC_MODEL=claude-sonnet-4-5 for premium output (~$0.015–$0.030 per report).
# Recommended: set a monthly spend cap on your Anthropic console.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────────────────────
# Legacy / unused — left for future re-introduction
# ─────────────────────────────────────────────────────────────────────────────
# PocketBase (currently disabled — Colorlight is the source of truth)
# POCKETBASE_URL=http://127.0.0.1:8090
# POCKETBASE_ADMIN_EMAIL=admin@digilite.com
# POCKETBASE_ADMIN_PASSWORD=your-admin-password

# Old Colorlight bearer auth (NOT used — left as historical reference)
# COLORLIGHT_API_KEY=your-colorlight-api-key
